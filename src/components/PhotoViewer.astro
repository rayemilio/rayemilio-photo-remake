---
import { getImage } from "astro:assets";
import type { Gallery, GalleryPhoto } from "../lib/gallery";
import "../styles/global.css";

type Props = {
  gallery: Gallery;
  photo: GalleryPhoto;
};

const { gallery, photo } = Astro.props;
const pageTitle = `${photo.caption || photo.slug} | ${gallery.title}`;
const currentPhotoIndex = gallery.photos.findIndex((galleryPhoto) => galleryPhoto.href === photo.href);
const previousPhoto = currentPhotoIndex > 0 ? gallery.photos[currentPhotoIndex - 1] : undefined;
const nextPhoto = currentPhotoIndex >= 0 ? gallery.photos[currentPhotoIndex + 1] : undefined;
const optimizedPhoto = photo.isSvg
  ? undefined
  : await getImage({
      src: photo.image,
      width: Math.min(photo.width, 2400),
      format: "webp",
      quality: 90
    });
const [previousPrefetchImage, nextPrefetchImage] = await Promise.all(
  [previousPhoto, nextPhoto].map(async (adjacentPhoto) => {
    if (!adjacentPhoto) {
      return undefined;
    }

    if (adjacentPhoto.isSvg) {
      return adjacentPhoto.image.src;
    }

    const optimizedAdjacentPhoto = await getImage({
      src: adjacentPhoto.image,
      width: Math.min(adjacentPhoto.width, 2400),
      format: "webp",
      quality: 90
    });

    return optimizedAdjacentPhoto.src;
  })
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={photo.caption || photo.alt || gallery.title} />
    <title>{pageTitle}</title>
    {previousPhoto && <link rel="prefetch" href={previousPhoto.href} />}
    {nextPhoto && <link rel="prefetch" href={nextPhoto.href} />}
    {previousPrefetchImage && <link rel="prefetch" as="image" href={previousPrefetchImage} />}
    {nextPrefetchImage && <link rel="prefetch" as="image" href={nextPrefetchImage} />}
    <script is:inline>
      document.documentElement.classList.add("photo-transition-enabled");
    </script>
  </head>
  <body class="photo-page">
    <main class="photo-route">
      <a class="photo-close" href={gallery.href} aria-label={`Close ${photo.caption || photo.slug}`}>
        <svg class="photo-close-icon" viewBox="0 0 44 44" aria-hidden="true">
          <path d="M26.668 22L40.77 7.899l2.908-2.908a1.1 1.1 0 000-1.555L40.567.323a1.1 1.1 0 00-1.556 0l-17.01 17.01L4.99.323a1.1 1.1 0 00-1.555 0L.322 3.433a1.1 1.1 0 000 1.556L17.334 22 .322 39.01a1.1 1.1 0 000 1.556l3.111 3.111a1.1 1.1 0 001.556 0L22 26.668 36.103 40.77l2.908 2.908a1.1 1.1 0 001.556 0l3.111-3.111a1.1 1.1 0 000-1.556l-17.01-17.01z"></path>
        </svg>
      </a>

      {previousPhoto && (
        <a
          class="photo-arrow photo-arrow-prev"
          href={previousPhoto.href}
          aria-label="Previous photo"
          data-prefetch-href={previousPhoto.href}
          data-prefetch-image={previousPrefetchImage}
        />
      )}

      {nextPhoto && (
        <a
          class="photo-arrow photo-arrow-next"
          href={nextPhoto.href}
          aria-label="Next photo"
          data-prefetch-href={nextPhoto.href}
          data-prefetch-image={nextPrefetchImage}
        />
      )}

      <figure class="photo-figure">
        <div class="photo-frame">
          {photo.isSvg ? (
            <img
              src={photo.image.src}
              width={photo.width}
              height={photo.height}
              alt={photo.alt}
              decoding="async"
              loading="eager"
            />
          ) : (
            <img
              src={optimizedPhoto?.src}
              width={optimizedPhoto?.attributes.width}
              height={optimizedPhoto?.attributes.height}
              alt={photo.alt}
              loading="eager"
              decoding="async"
            />
          )}
        </div>
        {(photo.caption || photo.details) && (
          <figcaption class="photo-caption">
            {photo.caption && <span>{photo.caption}</span>}
            {photo.details && <span>{photo.details}</span>}
          </figcaption>
        )}
      </figure>
    </main>
    <script>
      const transitionMs = 180;
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      const image = document.querySelector<HTMLImageElement>(".photo-frame img");
      const closeLink = document.querySelector<HTMLAnchorElement>(".photo-close");
      const previousLink = document.querySelector<HTMLAnchorElement>(".photo-arrow-prev");
      const nextLink = document.querySelector<HTMLAnchorElement>(".photo-arrow-next");
      const adjacentLinks = [nextLink, previousLink].filter((link): link is HTMLAnchorElement => Boolean(link));
      const warmedImages = new Set<string>();
      const warmedPages = new Set<string>();

      async function waitForPhotoImage() {
        if (!image) {
          return;
        }

        if (image.complete) {
          await image.decode?.().catch(() => undefined);
          return;
        }

        await new Promise<void>((resolve) => {
          image.addEventListener("load", () => resolve(), { once: true });
          image.addEventListener("error", () => resolve(), { once: true });
        });
      }

      function waitForFadeOut() {
        return new Promise<void>((resolve) => {
          window.setTimeout(resolve, transitionMs);
        });
      }

      async function revealPhoto() {
        await waitForPhotoImage();
        requestAnimationFrame(() => {
          document.body.classList.add("photo-ready");
          warmAdjacentPhotos();
        });
      }

      function warmImage(src: string) {
        if (!src || warmedImages.has(src)) {
          return;
        }

        warmedImages.add(src);
        const warmImage = new Image();
        warmImage.decoding = "async";
        warmImage.src = src;
        void warmImage.decode?.().catch(() => undefined);
      }

      function warmPage(href: string) {
        if (!href || warmedPages.has(href)) {
          return;
        }

        warmedPages.add(href);
        void fetch(href, { credentials: "same-origin" }).catch(() => undefined);
      }

      function warmAdjacentPhotos() {
        const warm = () => {
          adjacentLinks.forEach((link) => {
            warmPage(link.dataset.prefetchHref || link.href);
            warmImage(link.dataset.prefetchImage || "");
          });
        };

        if ("requestIdleCallback" in window) {
          window.requestIdleCallback(warm, { timeout: 600 });
          return;
        }

        setTimeout(warm, 120);
      }

      revealPhoto();

      let isNavigating = false;

      async function navigateTo(url: string, fadeOut = false) {
        if (isNavigating) {
          return;
        }

        isNavigating = true;

        if (fadeOut && !reduceMotion.matches) {
          document.body.classList.add("photo-leaving");
          await waitForFadeOut();
        }

        window.location.href = url;
      }

      closeLink?.addEventListener("click", async (event) => {
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
          return;
        }

        event.preventDefault();
        await navigateTo(closeLink.href, true);
      });

      document.querySelectorAll<HTMLAnchorElement>(".photo-arrow").forEach((link) => {
        link.addEventListener("click", async (event) => {
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || isNavigating) {
            return;
          }

          event.preventDefault();
          await navigateTo(link.href);
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || isNavigating) {
          return;
        }

        if (event.key === "Escape" && closeLink) {
          event.preventDefault();
          void navigateTo(closeLink.href, true);
        }

        if (event.key === "ArrowLeft" && previousLink) {
          event.preventDefault();
          void navigateTo(previousLink.href);
        }

        if (event.key === "ArrowRight" && nextLink) {
          event.preventDefault();
          void navigateTo(nextLink.href);
        }
      });
    </script>
  </body>
</html>
