---
import { getGalleries, getSiteContent } from "../lib/gallery";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const site = getSiteContent();
const galleries = getGalleries();
const pageTitle = Astro.props.title ? `${Astro.props.title} | ${site.title}` : site.title;
const description = Astro.props.description ?? site.description;
const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname === href || pathname.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <aside class="site-nav" aria-label="Primary navigation">
        <a class="site-brand" href="/">
          <span class="site-title">{site.title}</span>
          <span class="site-subtitle">{site.subtitle}</span>
        </a>
        <nav class="nav-links">
          {galleries.map((gallery) => (
            <a class:list={{ active: isActive(gallery.href) }} href={gallery.href}>
              {gallery.title.toLowerCase()}
            </a>
          ))}
          <a class:list={{ active: isActive("/artist-statement/") }} href="/artist-statement/">artist statement</a>
          <a href="https://rayemilio.darkroom.com/" target="_blank" rel="noopener noreferrer">buy prints</a>
        </nav>
      </aside>

      <header class="mobile-header">
        <a class="mobile-title" href="/">
          <span class="site-title">{site.title}</span>
          <span class="site-subtitle">{site.subtitle}</span>
        </a>
        <button class="mobile-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" aria-label="Toggle navigation">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>
      </header>

      <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation" hidden>
        {galleries.map((gallery) => (
          <a class:list={{ active: isActive(gallery.href) }} href={gallery.href}>
            {gallery.title.toLowerCase()}
          </a>
        ))}
        <a class:list={{ active: isActive("/artist-statement/") }} href="/artist-statement/">artist statement</a>
        <a href="https://rayemilio.darkroom.com/" target="_blank" rel="noopener noreferrer">buy prints</a>
      </nav>

      <main class="site-main">
        <slot />
      </main>
    </div>

    <script>
      const mobileHeader = document.querySelector<HTMLElement>(".mobile-header");
      const toggle = document.querySelector<HTMLButtonElement>(".mobile-toggle");
      const mobileNav = document.querySelector<HTMLElement>("#mobile-nav");
      const mobileHeaderQuery = window.matchMedia("(max-width: 760px)");
      let lastScrollY = Math.max(window.scrollY, 0);
      let isScrollUpdateQueued = false;

      function setMobileHeaderHidden(isHidden: boolean) {
        mobileHeader?.classList.toggle("mobile-header-hidden", isHidden);
      }

      function setMobileNavOpen(isOpen: boolean) {
        toggle?.setAttribute("aria-expanded", String(isOpen));
        if (mobileNav) {
          mobileNav.hidden = !isOpen;
        }
        document.documentElement.classList.toggle("mobile-nav-open", isOpen);
        document.body.classList.toggle("mobile-nav-open", isOpen);
        if (isOpen) {
          setMobileHeaderHidden(false);
        }
      }

      function updateMobileHeaderVisibility() {
        isScrollUpdateQueued = false;

        if (!mobileHeader || !mobileHeaderQuery.matches || toggle?.getAttribute("aria-expanded") === "true") {
          setMobileHeaderHidden(false);
          lastScrollY = Math.max(window.scrollY, 0);
          return;
        }

        const currentScrollY = Math.max(window.scrollY, 0);
        const scrollDelta = currentScrollY - lastScrollY;
        const hideStart = Math.max(160, mobileHeader.offsetHeight + 72);

        if (currentScrollY <= 24) {
          setMobileHeaderHidden(false);
        } else if (scrollDelta > 8 && currentScrollY > hideStart) {
          setMobileHeaderHidden(true);
        } else if (scrollDelta < -8) {
          setMobileHeaderHidden(false);
        }

        lastScrollY = currentScrollY;
      }

      function queueMobileHeaderVisibilityUpdate() {
        if (isScrollUpdateQueued) {
          return;
        }

        isScrollUpdateQueued = true;
        window.requestAnimationFrame(updateMobileHeaderVisibility);
      }

      toggle?.addEventListener("click", () => {
        const isOpen = toggle.getAttribute("aria-expanded") === "true";

        setMobileNavOpen(!isOpen);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && toggle?.getAttribute("aria-expanded") === "true") {
          setMobileNavOpen(false);
          toggle.focus();
        }
      });

      window.addEventListener("scroll", queueMobileHeaderVisibilityUpdate, { passive: true });
      mobileHeaderQuery.addEventListener("change", updateMobileHeaderVisibility);
    </script>
  </body>
</html>
