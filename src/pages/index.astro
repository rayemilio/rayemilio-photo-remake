---
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPhotoByRef, getSiteContent } from "../lib/gallery";

const site = getSiteContent();
const homePhoto = getPhotoByRef(site.home.photo);
const optimizedHomePhoto = homePhoto && !homePhoto.isSvg
  ? await getImage({
      src: homePhoto.image,
      width: Math.min(homePhoto.width, 1200),
      format: "webp",
      quality: 88
    })
  : undefined;
---

<BaseLayout>
  <section class="home-hero" aria-label="Home">
    {homePhoto && (
      <a class="home-image" href={homePhoto.href}>
        {homePhoto.isSvg ? (
          <img
            src={homePhoto.image.src}
            width={homePhoto.width}
            height={homePhoto.height}
            alt={homePhoto.alt}
            loading="eager"
            decoding="async"
          />
        ) : (
          <img
            src={optimizedHomePhoto?.src}
            width={optimizedHomePhoto?.attributes.width}
            height={optimizedHomePhoto?.attributes.height}
            alt={homePhoto.alt}
            loading="eager"
            decoding="async"
          />
        )}
      </a>
    )}

    <blockquote class="home-quote">
      <p>{site.home.quote}</p>
      {site.home.quoteCredit && <cite>{site.home.quoteCredit}</cite>}
    </blockquote>
  </section>
</BaseLayout>
