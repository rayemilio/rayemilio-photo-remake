---
import { getImage } from "astro:assets";
import homeImage from "../assets/home-statue-light.jpeg";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteContent } from "../lib/gallery";

const site = getSiteContent();
const optimizedHomePhoto = await getImage({
  src: homeImage,
  width: Math.min(homeImage.width, 1200),
  format: "webp",
  quality: 88
});
---

<BaseLayout>
  <section class="home-hero" aria-label="Home">
    <div class="home-image">
      <img
        src={optimizedHomePhoto.src}
        width={optimizedHomePhoto.attributes.width}
        height={optimizedHomePhoto.attributes.height}
        alt={site.home.alt}
        loading="eager"
        decoding="async"
      />
    </div>

    <blockquote class="home-quote">
      <p>{site.home.quote}</p>
      {site.home.quoteCredit && <cite>{site.home.quoteCredit}</cite>}
    </blockquote>
  </section>
</BaseLayout>
