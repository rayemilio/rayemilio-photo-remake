---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteContent } from "../lib/gallery";

const site = getSiteContent();
---

<BaseLayout title="About" description={site.description}>
  <article class="about-page">
    <div class="about-photo-slot" aria-hidden="true"></div>
    <h1>{site.about.heading}</h1>
    <blockquote>
      <p>“{site.about.quote}”</p>
      <cite>{site.about.quoteCredit}</cite>
    </blockquote>
    <div class="about-body">
      {site.about.body.map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <address class="about-contact">
      {site.about.contact.map((line) => <span>{line}</span>)}
    </address>
  </article>
</BaseLayout>
